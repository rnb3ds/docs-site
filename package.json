{
  "name": "cybergodev-docs",
  "version": "1.0.0",
  "description": "CyberGo project documentation website",
  "type": "module",
  "scripts": {
    "dev": "vitepress dev docs",
    "build": "node --max-old-space-size=8192 ./node_modules/vitepress/bin/vitepress.js build docs && tsx scripts/fix-clean-urls.ts && tsx scripts/generate-project-redirects.ts && tsx scripts/generate-moved-redirects.ts && tsx scripts/generate-llms.ts && tsx scripts/generate-md-mirror.ts",
    "preview": "vitepress preview docs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "vue-tsc --noEmit",
    "check:projects": "tsx scripts/check-projects-sync.ts",
    "check:code": "tsx scripts/check-code-samples.ts",
    "audit": "tsx scripts/audit-locales.ts",
    "audit:api": "tsx scripts/audit-api.ts",
    "lint:autocorrect": "autocorrect --lint",
    "fix:autocorrect": "autocorrect --fix"
  },
  "keywords": [
    "go",
    "golang",
    "docs",
    "vitepress"
  ],
  "author": "CyberGo",
  "license": "MIT",
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^26.1.1",
    "js-yaml": "^5.2.1",
    "png-to-ico": "^3.0.1",
    "prettier": "^3.4.2",
    "sharp": "^0.34.5",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "vitepress": "^1.6.4",
    "vitepress-plugin-mermaid": "^2.0.17",
    "vue-tsc": "^3.3.7"
  }
}
